/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data: blob: https://image.tmdb.org https://images.unsplash.com https://img.clerk.com https://images.clerk.dev https://oktowatch.com; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com https://thorough-anteater-20.clerk.accounts.dev; connect-src 'self' https://api.clerk.com https://thorough-anteater-20.clerk.accounts.dev; frame-src 'self' https://thorough-anteater-20.clerk.accounts.dev; form-action 'self' https://thorough-anteater-20.clerk.accounts.dev; manifest-src 'self'; media-src 'self' blob:; worker-src 'self' blob:
  Referrer-Policy: strict-origin-when-cross-origin
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

# HTML pages: always revalidate so deployments are instant
/dashboard/
  Cache-Control: no-cache, must-revalidate

/index/
  Cache-Control: no-cache, must-revalidate

/search/
  Cache-Control: no-cache, must-revalidate

/settings/
  Cache-Control: no-cache, must-revalidate

/profiles/
  Cache-Control: no-cache, must-revalidate

/lists/
  Cache-Control: no-cache, must-revalidate

/history/
  Cache-Control: no-cache, must-revalidate

/discover/
  Cache-Control: no-cache, must-revalidate

/plans/
  Cache-Control: no-cache, must-revalidate

/signin/
  Cache-Control: no-cache, must-revalidate

/signup/
  Cache-Control: no-cache, must-revalidate

/about/
  Cache-Control: no-cache, must-revalidate

/contact/
  Cache-Control: no-cache, must-revalidate

/privacy/
  Cache-Control: no-cache, must-revalidate

/how-it-works/
  Cache-Control: no-cache, must-revalidate

/cv-admin/
  Cache-Control: no-cache, must-revalidate

# API: never cache
/api/*
  Cache-Control: no-cache, no-store, must-revalidate

# Static assets: cache aggressively (they're content-hashed / immutable)
/css/*
  Cache-Control: public, max-age=86400, must-revalidate

/js/*
  Cache-Control: public, max-age=86400, must-revalidate

/icons/*
  Cache-Control: public, max-age=31536000, immutable

/manifest.json
  Cache-Control: public, max-age=3600

# Fallback for everything else
/*
  Cache-Control: public, max-age=300, must-revalidate
